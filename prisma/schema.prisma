// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum GiftType {
  OFFLINE
  ONLINE
}

enum EventSide {
  BRIDE
  GROOM
}

enum MediaType {
  IMAGE
  VIDEO
}

enum AnalyticsEventType {
  VIEW
  CLICK
  RSVP
}

model User {
  id          String           @id @default(uuid())
  name        String
  email       String           @unique
  password    String
  avatarUrl   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  projects    WeddingProject[]
  memberships ProjectMember[]

  @@index([email])
}

model Template {
  id          String           @id @default(uuid())
  name        String
  thumbnail   String
  previewUrl  String?
  config      Json
  isPremium   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  projects    WeddingProject[]
}

model WeddingProject {
  id           String          @id @default(uuid())
  userId       String
  templateId   String
  title        String?
  slug         String          @unique
  isPublished  Boolean         @default(false)
  publishedAt  DateTime?
  coverImage   String?
  themeConfig  Json? // color, font, style
  version      Int             @default(1)
  deletedAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  
  user         User            @relation(fields: [userId], references: [id])
  template     Template        @relation(fields: [templateId], references: [id])
  sections     Section[]
  events       EventInfo[]
  media        Media[]
  gift         Gift?
  rsvps        RSVP[]
  guestGroups  GuestGroup[]
  analytics    Analytics[]
  members      ProjectMember[]
  slugHistory  SlugHistory[]

  @@index([userId])
  @@index([slug])
  @@index([createdAt])
}

model ProjectMember {
  id        String         @id @default(uuid())
  userId    String
  projectId String
  role      String         // owner | editor
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
  project   WeddingProject @relation(fields: [projectId], references: [id])

  @@unique([userId, projectId])
}

model Section {
  id          String         @id @default(uuid())
  projectId   String
  type        String         // hero | story | gallery | rsvp | gift...
  content     Json           // flexible data
  order       Int
  isVisible   Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  project     WeddingProject @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([order])
}

model RSVP {
  id           String         @id @default(uuid())
  projectId    String
  groupId      String?
  name         String
  phone        String?
  relationship String
  message      String?
  attending    Boolean
  guestCount   Int?
  giftType     GiftType
  createdAt    DateTime       @default(now())
  project      WeddingProject @relation(fields: [projectId], references: [id])
  group        GuestGroup?    @relation(fields: [groupId], references: [id])

  @@index([projectId])
  @@index([groupId])
}

model GuestGroup {
  id        String         @id @default(uuid())
  projectId String
  name      String
  project   WeddingProject @relation(fields: [projectId], references: [id])
  rsvps     RSVP[]
}

model Gift {
  id            String         @id @default(uuid())
  projectId     String         @unique
  bankName      String
  accountNumber String
  accountName   String
  qrImageUrl    String
  createdAt     DateTime       @default(now())
  project       WeddingProject @relation(fields: [projectId], references: [id])
}

model EventInfo {
  id        String         @id @default(uuid())
  projectId String
  side      EventSide
  title     String
  date      DateTime
  location  String
  address   String
  mapUrl    String?
  project   WeddingProject @relation(fields: [projectId], references: [id])
}

model Media {
  id        String         @id @default(uuid())
  projectId String
  type      MediaType
  url       String
  order     Int
  project   WeddingProject @relation(fields: [projectId], references: [id])
}

model Analytics {
  id        String             @id @default(uuid())
  projectId String
  eventType AnalyticsEventType
  metadata  Json?
  createdAt DateTime           @default(now())
  project   WeddingProject     @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([eventType])
}

model SlugHistory {
  id        String         @id @default(uuid())
  projectId String
  slug      String         @unique
  createdAt DateTime       @default(now())
  project   WeddingProject @relation(fields: [projectId], references: [id])

  @@index([projectId])
}
